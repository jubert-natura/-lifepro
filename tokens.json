{
  "$schema": "https://schemas.tr.designtokens.org/format/",
  "color": {
    "brand": {
      "primary":         { "$value": "#F15A29", "$type": "color" },
      "primary-hover":   { "$value": "#D94818", "$type": "color" },
      "primary-pressed": { "$value": "#B83A12", "$type": "color" },
      "ink":             { "$value": "#1A1A1A", "$type": "color" }
    },
    "accent": {
      "peach":      { "$value": "#FFE5D6", "$type": "color" },
      "periwinkle": { "$value": "#C8D0E0", "$type": "color" }
    },
    "neutral": {
      "white": { "$value": "#FFFFFF", "$type": "color" },
      "25":    { "$value": "#FAFAFA", "$type": "color" },
      "50":    { "$value": "#F7F8FA", "$type": "color" },
      "100":   { "$value": "#EEF1F5", "$type": "color" },
      "150":   { "$value": "#E4E7EC", "$type": "color" },
      "200":   { "$value": "#D9DEE5", "$type": "color" },
      "400":   { "$value": "#8A93A1", "$type": "color" },
      "600":   { "$value": "#4A5160", "$type": "color" },
      "900":   { "$value": "#111418", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#2BA66B", "$type": "color" },
      "error":   { "$value": "#D93025", "$type": "color" },
      "warning": { "$value": "#F4B400", "$type": "color" },
      "info":    { "$value": "#2F6FED", "$type": "color" },
      "star":    { "$value": "#F4B400", "$type": "color" }
    }
  },
  "spacing": {
    "2xs":     { "$value": "4px",  "$type": "dimension" },
    "xs":      { "$value": "8px",  "$type": "dimension" },
    "sm":      { "$value": "12px", "$type": "dimension" },
    "md":      { "$value": "16px", "$type": "dimension" },
    "lg":      { "$value": "24px", "$type": "dimension" },
    "xl":      { "$value": "32px", "$type": "dimension" },
    "2xl":     { "$value": "40px", "$type": "dimension" },
    "3xl":     { "$value": "56px", "$type": "dimension" },
    "4xl":     { "$value": "64px", "$type": "dimension" },
    "section": { "$value": "96px", "$type": "dimension" }
  },
  "padding": {
    "button-y":  { "$value": "12px", "$type": "dimension" },
    "button-x":  { "$value": "24px", "$type": "dimension" },
    "input-y":   { "$value": "12px", "$type": "dimension" },
    "input-x":   { "$value": "16px", "$type": "dimension" },
    "card":      { "$value": "20px", "$type": "dimension" },
    "container": { "$value": "64px", "$type": "dimension" },
    "navbar-x":  { "$value": "32px", "$type": "dimension" },
    "navbar-y":  { "$value": "16px", "$type": "dimension" }
  },
  "sizing": {
    "screen-width":      { "$value": "1440px", "$type": "dimension" },
    "container-max":     { "$value": "1200px", "$type": "dimension" },
    "navbar-height":     { "$value": "64px",   "$type": "dimension" },
    "button-min-width":  { "$value": "120px",  "$type": "dimension" },
    "input-height":      { "$value": "48px",   "$type": "dimension" },
    "card-width":        { "$value": "320px",  "$type": "dimension" },
    "card-image-height": { "$value": "180px",  "$type": "dimension" },
    "icon-sm":           { "$value": "16px",   "$type": "dimension" },
    "icon-md":           { "$value": "24px",   "$type": "dimension" },
    "icon-lg":           { "$value": "32px",   "$type": "dimension" }
  },
  "radius": {
    "sm":   { "$value": "6px",   "$type": "dimension" },
    "md":   { "$value": "10px",  "$type": "dimension" },
    "lg":   { "$value": "16px",  "$type": "dimension" },
    "xl":   { "$value": "24px",  "$type": "dimension" },
    "full": { "$value": "999px", "$type": "dimension" },
    "pill": { "$value": "999px", "$type": "dimension" }
  },
  "shadow": {
    "xs":         { "$value": { "offsetX": "0px", "offsetY": "1px",  "blur": "2px",  "spread": "0px", "color": "rgba(17,20,24,0.06)" }, "$type": "shadow" },
    "sm":         { "$value": { "offsetX": "0px", "offsetY": "2px",  "blur": "6px",  "spread": "0px", "color": "rgba(17,20,24,0.08)" }, "$type": "shadow" },
    "card":       { "$value": { "offsetX": "0px", "offsetY": "4px",  "blur": "14px", "spread": "0px", "color": "rgba(17,20,24,0.08)" }, "$type": "shadow" },
    "card-hover": { "$value": { "offsetX": "0px", "offsetY": "10px", "blur": "28px", "spread": "0px", "color": "rgba(17,20,24,0.12)" }, "$type": "shadow" },
    "modal":      { "$value": { "offsetX": "0px", "offsetY": "24px", "blur": "60px", "spread": "0px", "color": "rgba(17,20,24,0.22)" }, "$type": "shadow" },
    "cta":        { "$value": { "offsetX": "0px", "offsetY": "6px",  "blur": "16px", "spread": "0px", "color": "rgba(241,90,41,0.25)" }, "$type": "shadow" }
  },
  "font": {
    "family": {
      "base":    { "$value": ["area-normal", "sans-serif"], "$type": "fontFamily" },
      "display": { "$value": ["area-normal", "sans-serif"], "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "display-1": { "$value": "56px", "$type": "dimension" },
      "display-2": { "$value": "48px", "$type": "dimension" },
      "h1":        { "$value": "36px", "$type": "dimension" },
      "h2":        { "$value": "34px", "$type": "dimension" },
      "h3":        { "$value": "28px", "$type": "dimension" },
      "h4":        { "$value": "22px", "$type": "dimension" },
      "subtitle":  { "$value": "18px", "$type": "dimension" },
      "body-xl":   { "$value": "18px", "$type": "dimension" },
      "body-lg":   { "$value": "16px", "$type": "dimension" },
      "body-md":   { "$value": "16px", "$type": "dimension" },
      "body-sm":   { "$value": "14px", "$type": "dimension" },
      "caption":   { "$value": "12px", "$type": "dimension" },
      "button":    { "$value": "18px", "$type": "dimension" }
    },
    "lineHeight": {
      "display-xl": { "$value": 1.05, "$type": "number" },
      "h1":         { "$value": 1.10, "$type": "number" },
      "h2":         { "$value": 1.15, "$type": "number" },
      "h3":         { "$value": 1.20, "$type": "number" },
      "h4":         { "$value": 1.30, "$type": "number" },
      "eyebrow":    { "$value": 1.40, "$type": "number" },
      "body-l":     { "$value": 1.55, "$type": "number" },
      "body-m":     { "$value": 1.50, "$type": "number" },
      "body-s":     { "$value": 1.40, "$type": "number" },
      "caption":    { "$value": 1.40, "$type": "number" },
      "button":     { "$value": 1.00, "$type": "number" }
    },
    "letterSpacing": {
      "display-xl": { "$value": "-0.02em", "$type": "dimension" },
      "h1":         { "$value": "-0.02em", "$type": "dimension" },
      "eyebrow":    { "$value": "0.12em",  "$type": "dimension" },
      "button":     { "$value": "0.04em",  "$type": "dimension" }
    }
  }
}
